{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "thearcheryexpert",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist",
    "not_found_handling": "none"
  },
  "observability": {
    "enabled": true
  }
}

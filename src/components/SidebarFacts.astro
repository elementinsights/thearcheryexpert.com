---
interface Props {
  items: {
    value: string;
    label: string;
  }[];
}

const { items } = Astro.props;
---

<div class="widget sidebar-facts">
  <h3 class="widget-title">Quick Facts</h3>
  {items.map(item => (
    <div class="fact-item">
      <div class="fact-value">{item.value}</div>
      <div class="fact-desc">{item.label}</div>
    </div>
  ))}
</div>

<style>
  .widget {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 22px;
  }
  .widget-title {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--accent);
    display: block;
  }
  .fact-item {
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    text-align: center;
  }
  .fact-item:first-of-type { padding-top: 0; }
  .fact-item:last-child { border-bottom: none; padding-bottom: 0; }
  .fact-value {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 4px;
  }
  .fact-desc {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-secondary);
    line-height: 1.4;
  }
</style>

---
interface Props {
  items: {
    name: string;
    image: string;
    rating: string;
    rank: number;
    ctaUrl?: string;
  }[];
}

const { items } = Astro.props;

function renderStars(ratingStr: string): string {
  const val = parseFloat(ratingStr) / 2;
  const rounded = Math.round(val * 2) / 2;
  const full = Math.floor(rounded);
  const half = rounded > full ? 1 : 0;
  const empty = 5 - full - half;
  return '★'.repeat(full) + (half ? '<span class="star-half">☆</span>' : '') + '☆'.repeat(empty);
}
---

<div class="widget sidebar-picks">
  <h3 class="widget-title">Our Top Picks</h3>
  <div class="sidebar-picks-grid">
    {items.map(item => (
      <div class="sidebar-pick">
        <a href={item.ctaUrl || '#'} class="sidebar-pick-img" target="_blank" rel="nofollow sponsored">
          <div class="sidebar-pick-badge">#{item.rank}</div>
          <img src={item.image} alt={item.name} loading="lazy" width="48" height="48" />
        </a>
        <div class="sidebar-pick-info">
          <div class="sidebar-pick-name">{item.name}</div>
          <div class="sidebar-pick-rating"><span class="stars" set:html={renderStars(item.rating)} /> {item.rating}</div>
        </div>
        <a href={item.ctaUrl || '#'} class="sidebar-pick-cta" rel="nofollow sponsored" target="_blank">Check Price</a>
      </div>
    ))}
  </div>
</div>

<style>
  .widget {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 22px;
  }
  .widget-title {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--accent);
    display: block;
  }
  .sidebar-picks-grid {
    display: flex;
    flex-direction: column;
  }
  .sidebar-pick {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .sidebar-pick:first-child { padding-top: 0; }
  .sidebar-pick:last-child { border-bottom: none; padding-bottom: 0; }
  .sidebar-pick-img {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg-alt);
    position: relative;
  }
  .sidebar-pick-img img { width: 100%; height: 100%; object-fit: cover; }
  .sidebar-pick-badge {
    position: absolute;
    top: -1px;
    left: 0;
    font-size: 9px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #fff;
    background: var(--accent);
    padding: 1px 6px;
    border-radius: 0 0 4px 0;
  }
  .sidebar-pick-info { flex: 1; min-width: 0; }
  .sidebar-pick-name { font-size: 13px; font-weight: 700; line-height: 1.3; }
  .sidebar-pick-rating { font-size: 12px; color: var(--text-secondary); }
  .sidebar-pick-rating .stars { color: #f59e0b; font-size: 11px; }
  .star-half {
    position: relative;
    display: inline-block;
  }
  .star-half::before {
    content: '★';
    position: absolute;
    left: 0;
    width: 50%;
    overflow: hidden;
  }
  .sidebar-pick-cta {
    display: inline-block;
    padding: 6px 12px;
    flex-shrink: 0;
    background: var(--accent);
    color: #fff !important;
    border-radius: var(--radius);
    font-size: 12px;
    font-weight: 700;
    text-decoration: none !important;
    transition: background var(--transition);
    white-space: nowrap;
  }
  .sidebar-pick-cta:hover { background: var(--accent-hover); }
</style>

---
interface Props {
  items: {
    name: string;
    image: string;
    rating: string;
    vsUrl?: string;
  }[];
}

const { items } = Astro.props;
---

<div class="widget sidebar-alternatives">
  <h3 class="widget-title">Compare Alternatives</h3>
  {items.map(item => (
    <div class="sidebar-alt-item">
      <a href={item.vsUrl || '#'} class="sidebar-alt-img" target="_blank" rel="nofollow sponsored noopener noreferrer">
        <img src={item.image} alt={item.name} loading="lazy" />
      </a>
      <div class="sidebar-alt-info">
        <div class="sidebar-alt-name">{item.name}</div>
        <div class="sidebar-alt-rating"><span class="stars">{'★'.repeat(Math.round(parseFloat(item.rating)))}{'☆'.repeat(5 - Math.round(parseFloat(item.rating)))}</span> {item.rating}</div>
      </div>
      <a href={item.vsUrl || '#'} class="sidebar-alt-vs" target="_blank" rel="nofollow sponsored noopener noreferrer">vs.</a>
    </div>
  ))}
</div>

<style>
  .widget {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 22px;
  }
  .widget-title {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--accent);
    display: block;
  }
  .sidebar-alt-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .sidebar-alt-item:first-of-type { padding-top: 0; }
  .sidebar-alt-item:last-of-type { border-bottom: none; padding-bottom: 0; }
  .sidebar-alt-img {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg-alt);
  }
  .sidebar-alt-img img { width: 100%; height: 100%; object-fit: cover; }
  .sidebar-alt-info { flex: 1; min-width: 0; }
  .sidebar-alt-name { font-size: 13px; font-weight: 700; line-height: 1.3; }
  .sidebar-alt-rating { font-size: 12px; color: var(--text-secondary); }
  .sidebar-alt-rating .stars { color: #f59e0b; font-size: 11px; }
  .sidebar-alt-vs {
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    flex-shrink: 0;
    padding: 4px 10px;
    border: 1px solid var(--accent);
    border-radius: 4px;
    transition: all var(--transition);
  }
  .sidebar-alt-vs:hover { background: var(--accent); color: #fff; }
</style>

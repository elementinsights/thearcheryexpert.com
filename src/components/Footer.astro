---
import { siteConfig } from '../../site.config';

const nameParts = siteConfig.name.split(siteConfig.nameHighlight);
const namePrefix = nameParts[0] || '';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        {siteConfig.logo ? (
          <a href="/" class="logo footer-logo-img"><img src={siteConfig.logo} alt={siteConfig.name} width="188" height="36" /></a>
        ) : (
          <a href="/" class="logo">{namePrefix}<span>{siteConfig.nameHighlight}</span></a>
        )}
        <p>{siteConfig.footerDescription}</p>
        <div class="footer-social">
          {siteConfig.social.facebook && (
            <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          )}
          {siteConfig.social.pinterest && (
            <a href={siteConfig.social.pinterest} target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641 0 12.017 0z"/></svg>
            </a>
          )}
          {siteConfig.social.twitter && (
            <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          )}
          {siteConfig.social.youtube && (
            <a href={siteConfig.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          )}
        </div>
      </div>
      <div class="footer-col">
        <h4>Categories</h4>
        <ul>
          {siteConfig.categories.map(cat => (
            <li><a href={`/category/${cat.slug}/`}>{cat.name}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <h4>Popular</h4>
        <ul>
          {siteConfig.footerPopularLinks.map(link => (
            <li><a href={link.href}>{link.name}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/about/">About</a></li>
          <li><a href="/contact/">Contact</a></li>
          <li><a href="/privacy-policy/">Privacy Policy</a></li>
          <li><a href="/disclosure/">Disclosure</a></li>
          <li><a href="/terms/">Terms</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {year} {siteConfig.name}. All rights reserved.</span>
      <div class="footer-links">
        <a href="/privacy-policy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="/sitemap.xml">Sitemap</a>
      </div>
    </div>
    {siteConfig.amazonDisclaimer && (
      <p class="footer-affiliate">{siteConfig.amazonDisclaimer}</p>
    )}
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-dark);
    color: rgba(255,255,255,0.6);
    padding: 55px 0 0;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .footer-brand .logo { color: #fff; margin-bottom: 14px; display: inline-block; font-size: 1.6rem; font-weight: 900; letter-spacing: -0.02em; }
  .footer-logo-img img { height: 36px; width: auto; display: block; filter: brightness(0) invert(1); }
  .footer-brand .logo span { color: var(--accent); }
  .footer-brand p { font-size: 14px; line-height: 1.7; margin-bottom: 18px; }
  .footer-social { display: flex; gap: 10px; }
  .footer-social a {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.6);
    font-size: 14px;
    transition: background var(--transition), color var(--transition);
  }
  .footer-social a[aria-label="Facebook"]:hover { background: #1877F2; color: #fff; }
  .footer-social a[aria-label="Pinterest"]:hover { background: #E60023; color: #fff; }
  .footer-social a[aria-label="Twitter"]:hover { background: #000; color: #fff; }
  .footer-social a[aria-label="YouTube"]:hover { background: #FF0000; color: #fff; }
  .footer-col h4 { color: #fff; font-size: 15px; font-weight: 700; margin-bottom: 18px; }
  .footer-col ul li { margin-bottom: 10px; }
  .footer-col ul a {
    color: rgba(255,255,255,0.5);
    font-size: 14px;
    transition: color var(--transition);
  }
  .footer-col ul a:hover { color: var(--accent); }
  .footer-bottom {
    padding: 20px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
  }
  .footer-bottom a { color: rgba(255,255,255,0.4); }
  .footer-bottom a:hover { color: var(--accent); }
  .footer-affiliate {
    text-align: center;
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    padding: 20px 0;
    line-height: 1.5;
  }
  .footer-links { display: flex; gap: 20px; }

  @media (max-width: 1024px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr; gap: 30px; }
    .footer-bottom { flex-direction: column; gap: 10px; text-align: center; }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../../site.config';

const cardColors = ['accent', 'teal', 'amber'];

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `Start Here - ${siteConfig.name}`,
  "description": `New to ${siteConfig.name}? Start here for the best guides, reviews, and resources to find the right products.`,
  "url": `${siteConfig.url}/start-here/`,
  "isPartOf": { "@type": "WebSite", "name": siteConfig.name, "url": siteConfig.url }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteConfig.url },
    { "@type": "ListItem", "position": 2, "name": "Start Here", "item": `${siteConfig.url}/start-here/` }
  ]
};

/* SVG icons for path cards — one per category (cycles if > 3) */
const pathIcons = [
  /* Drop / filter */
  `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
  /* Flame / heater */
  `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22c-4.97 0-9-2.69-9-6 0-4 5-11 9-14 4 3 9 10 9 14 0 3.31-4.03 6-9 6z"/><path d="M12 22c-1.66 0-3-1.12-3-2.5S10.34 15 12 15s3 3 3 4.5-1.34 2.5-3 2.5z"/></svg>`,
  /* Gear / softener */
  `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
];

/* Guide group labels + color keys */
const guideGroupLabels = ['Top Picks', 'Reviews & Comparisons', 'Learn'];
const guideGroupColors = ['top-picks', 'reviews', 'learn'];

/* Popular guides per group — uses footerPopularLinks + some placeholders */
const popularLinks = siteConfig.footerPopularLinks || [];
---

<BaseLayout
  title="Start Here"
  description={`New to ${siteConfig.name}? Start here for the best guides, reviews, and resources to find the right products.`}
  activeNav="start-here"
  schema={[pageSchema, breadcrumbSchema]}
>

<!-- ============================================================
     1. HERO
     ============================================================ -->
<section class="sh-hero">
  <div class="container">
    <h1 class="sh-hero-title animate-on-scroll">Welcome to {siteConfig.name}</h1>
    <p class="sh-hero-subtitle animate-on-scroll">Whether you're picking your first bow or upgrading your competition setup, we've got guides, gear reviews, and tips to help you shoot better.</p>
  </div>
</section>

<!-- ============================================================
     2. QUICK INTRO
     ============================================================ -->
<section class="sh-intro">
  <div class="container">
    <div class="sh-intro-inner animate-on-scroll">
      {siteConfig.author.image ? (
        <img class="sh-avatar-img" src={siteConfig.author.image} alt={siteConfig.author.name} width="80" height="80" style="object-position: top" />
      ) : (
        <div class="sh-avatar">{siteConfig.author.initial}</div>
      )}
      <div class="sh-intro-text">
        <p><strong>Hey, I'm {siteConfig.author.name}.</strong> I've been shooting bows for over 15 years, from backyard target practice to competitive 3D tournaments. I built The Archery Expert because I got tired of gear reviews written by people who've never drawn a bowstring. Every product on this site gets real range time before we write a single word.</p>
        <p>We've published 87 in-depth articles covering 395 individual products across bows, arrows, accessories, and targets. Whether you're shopping for your first recurve, upgrading your compound sight, or just learning proper form, the guides below will point you in the right direction.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     3. PICK YOUR PATH
     ============================================================ -->
<section class="sh-paths">
  <div class="container">
    <h2 class="sh-section-title animate-on-scroll">Pick Your Path</h2>
    <p class="sh-section-subtitle animate-on-scroll">Not sure where to start? Choose the category that fits your needs.</p>
    <div class="sh-paths-grid">
      {siteConfig.categories.map((cat, i) => {
        const color = cardColors[i % cardColors.length];
        return (
          <a href={`/category/${cat.slug}`} class={`sh-path-card sh-path-card--${color} animate-on-scroll`}>
            <div class={`sh-path-icon sh-path-icon--${color}`} set:html={pathIcons[i % pathIcons.length]} />
            <h3>I Need {cat.name}</h3>
            <p>{cat.name === 'Accessories' ? 'Arm guards, quivers, sights, releases, and every piece of gear that makes your setup complete.' :
               cat.name === 'Arrows' ? 'Carbon arrows, broadheads, vanes, and nocks. Find the right shaft and tip combo for your bow.' :
               cat.name === 'Bows' ? 'Compound, recurve, longbow, and youth bows. We cover every type from beginner to competition grade.' :
               cat.name === 'Knowledge' ? 'Shooting form, safety, scoring, history, and everything you need to become a better archer.' :
               cat.name === 'Targets' ? 'Bag targets, 3D animal targets, foam blocks, and DIY options for backyard and range practice.' :
               `Reviews and guides covering the best ${cat.name.toLowerCase()} for every skill level.`}</p>
            <span class="sh-path-link">Explore {cat.name} &rarr;</span>
          </a>
        );
      })}
    </div>
  </div>
</section>

<!-- ============================================================
     4. COMMON QUESTIONS
     ============================================================ -->
<section class="sh-problems">
  <div class="container">
    <h2 class="sh-section-title animate-on-scroll">What Are You Looking For?</h2>
    <p class="sh-section-subtitle animate-on-scroll">Jump straight to the guide that answers your question.</p>
    <div class="sh-problems-grid">
      <a href="/archery-for-beginners/" class="sh-problem-card animate-on-scroll">
        <span class="sh-problem-icon">&#127993;</span>
        <h3>I'm a Complete Beginner</h3>
        <p>12-step guide covering everything from choosing your first bow to hitting your first bullseye.</p>
      </a>
      <a href="/bow-and-arrow-set-for-beginners/" class="sh-problem-card animate-on-scroll">
        <span class="sh-problem-icon">&#127919;</span>
        <h3>I Need My First Bow</h3>
        <p>Beginner-friendly bow sets rated by value, quality, and ease of setup for new archers.</p>
      </a>
      <a href="/archery-form/" class="sh-problem-card animate-on-scroll">
        <span class="sh-problem-icon">&#128170;</span>
        <h3>My Form Needs Work</h3>
        <p>10-step guide to proper archery stance, grip, anchor point, and follow-through technique.</p>
      </a>
      <a href="/archery-accuracy-tips/" class="sh-problem-card animate-on-scroll">
        <span class="sh-problem-icon">&#127919;</span>
        <h3>I Want Better Accuracy</h3>
        <p>10 proven tips for tighter groupings in both target shooting and hunting scenarios.</p>
      </a>
      <a href="/barebow-recurve/" class="sh-problem-card animate-on-scroll">
        <span class="sh-problem-icon">&#127993;</span>
        <h3>I Shoot Traditional</h3>
        <p>Best recurve bows for barebow shooting, from takedown models to one-piece longbows.</p>
      </a>
      <a href="/archery-injuries/" class="sh-problem-card animate-on-scroll">
        <span class="sh-problem-icon">&#129657;</span>
        <h3>I'm Dealing With Pain</h3>
        <p>10 most common archery injuries and how to prevent them before they sideline your season.</p>
      </a>
    </div>
  </div>
</section>

<!-- ============================================================
     5. MOST POPULAR GUIDES
     ============================================================ -->
<section class="sh-guides">
  <div class="container">
    <h2 class="sh-section-title animate-on-scroll">Most Popular Guides</h2>
    <p class="sh-section-subtitle animate-on-scroll">The articles our readers keep coming back to, from gear roundups to shooting technique breakdowns.</p>
    <div class="sh-guides-groups">

      {/* Group 1: Top Picks */}
      <div class="animate-on-scroll">
        <span class="sh-guide-group-label sh-guide-group-label--top-picks">Top Picks</span>
        <div class="sh-guide-list">
          <a href="/bow-and-arrow-set-for-beginners/" class="sh-guide-item">
            <div class="sh-guide-item-title">Best Bow Sets for Beginners</div>
            <div class="sh-guide-item-desc">Youth and adult starter packages ranked by build quality, included accessories, and value for first-time archers.</div>
          </a>
          <a href="/barebow-recurve/" class="sh-guide-item">
            <div class="sh-guide-item-title">Best Barebow Recurve Bows</div>
            <div class="sh-guide-item-desc">Takedown and one-piece recurve bows rated for traditional barebow shooting, from entry-level to competition-grade.</div>
          </a>
          <a href="/2-blade-broadheads/" class="sh-guide-item">
            <div class="sh-guide-item-title">Best 2 Blade Broadheads</div>
            <div class="sh-guide-item-desc">Fixed and mechanical broadheads tested for penetration, flight consistency, and cutting diameter.</div>
          </a>
          <a href="/archery-arm-guard/" class="sh-guide-item">
            <div class="sh-guide-item-title">Best Archery Arm Guards</div>
            <div class="sh-guide-item-desc">Bracers and arm guards reviewed for string clearance, comfort, and protection during extended shooting sessions.</div>
          </a>
          <a href="/archery-bag-targets/" class="sh-guide-item">
            <div class="sh-guide-item-title">Best Archery Bag Targets</div>
            <div class="sh-guide-item-desc">Bag targets rated by stopping power, arrow removal ease, and weather resistance for backyard and range use.</div>
          </a>
        </div>
      </div>

      {/* Group 2: Reviews & Comparisons — next 2 footer links + categories */}
      <div class="animate-on-scroll">
        <span class="sh-guide-group-label sh-guide-group-label--reviews">Reviews &amp; Comparisons</span>
        <div class="sh-guide-list">
          {popularLinks.slice(2, 5).map(link => (
            <a href={link.href} class="sh-guide-item">
              <div class="sh-guide-item-title">{link.name}</div>
              {link.desc && <div class="sh-guide-item-desc">{link.desc}</div>}
            </a>
          ))}
          {siteConfig.categories.map(cat => (
            <a href={`/category/${cat.slug}`} class="sh-guide-item">
              <div class="sh-guide-item-title">{cat.name} Reviews</div>
              <div class="sh-guide-item-desc">Detailed side-by-side comparisons of the top {cat.name.toLowerCase()} on the market. We break down features, pricing, durability, and real-world performance so you can pick the right one.</div>
            </a>
          ))}
        </div>
      </div>

      {/* Group 3: Learn — about + category pages */}
      <div class="animate-on-scroll">
        <span class="sh-guide-group-label sh-guide-group-label--learn">Learn</span>
        <div class="sh-guide-list">
          <a href="/about/" class="sh-guide-item">
            <div class="sh-guide-item-title">About {siteConfig.name}</div>
            <div class="sh-guide-item-desc">How we evaluate archery gear and the story behind The Archery Expert.</div>
          </a>
          {siteConfig.categories.map(cat => (
            <a href={`/category/${cat.slug}`} class="sh-guide-item">
              <div class="sh-guide-item-title">{cat.name} Buying Guide</div>
              <div class="sh-guide-item-desc">A complete guide to choosing the right {cat.name.toLowerCase()} for your shooting style.</div>
            </a>
          ))}
          <a href="/contact/" class="sh-guide-item">
            <div class="sh-guide-item-title">Contact Us</div>
            <div class="sh-guide-item-desc">Have a question or feedback? We'd love to hear from you.</div>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

</BaseLayout>

<style>
  /* ============================================================
     HERO
     ============================================================ */
  .sh-hero {
    background: var(--bg-dark);
    padding: 80px 0 70px;
    text-align: center;
  }
  .sh-hero-title {
    font-size: 2.8rem;
    color: #fff;
    margin-bottom: 16px;
    line-height: 1.15;
  }
  .sh-hero-subtitle {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.65);
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ============================================================
     QUICK INTRO
     ============================================================ */
  .sh-intro {
    padding: 60px 0;
  }
  .sh-intro-inner {
    display: flex;
    align-items: flex-start;
    gap: 32px;
    max-width: 820px;
    margin: 0 auto;
  }
  .sh-avatar-img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
    flex-shrink: 0;
  }
  .sh-avatar {
    flex-shrink: 0;
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: 800;
    color: #fff;
  }
  .sh-intro-text {
    flex: 1;
  }
  .sh-intro-text p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }
  .sh-intro-text p:last-child { margin-bottom: 0; }
  .sh-intro-text strong { color: var(--text); font-weight: 700; }

  /* ============================================================
     PICK YOUR PATH
     ============================================================ */
  .sh-paths {
    background: var(--bg-alt);
    padding: 60px 0 65px;
  }
  .sh-section-title {
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 12px;
  }
  .sh-section-subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    text-align: center;
    max-width: 500px;
    margin: 0 auto 40px;
  }
  .sh-paths-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .sh-path-card {
    background: var(--bg);
    border-radius: var(--radius-lg);
    padding: 36px 28px 32px;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition), transform var(--transition);
    text-align: center;
    display: block;
    color: var(--text);
    border-top: 4px solid transparent;
  }
  .sh-path-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
    color: var(--text);
  }
  .sh-path-card--accent { border-top-color: var(--accent); }
  .sh-path-card--teal { border-top-color: #2dc0bb; }
  .sh-path-card--amber { border-top-color: #e8a317; }

  .sh-path-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    font-size: 24px;
  }
  .sh-path-icon--accent { background: var(--accent-light); color: var(--accent); }
  .sh-path-icon--teal { background: rgba(45,192,187,0.12); color: #2dc0bb; }
  .sh-path-icon--amber { background: rgba(232,163,23,0.12); color: #e8a317; }

  :global(html.dark) .sh-path-icon--teal { background: rgba(45,192,187,0.15); }
  :global(html.dark) .sh-path-icon--amber { background: rgba(232,163,23,0.15); }

  .sh-path-card h3 {
    font-size: 1.15rem;
    font-weight: 800;
    margin-bottom: 10px;
  }
  .sh-path-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 18px;
  }
  .sh-path-link {
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
    transition: color var(--transition);
  }
  .sh-path-card--teal .sh-path-link { color: #2dc0bb; }
  .sh-path-card--amber .sh-path-link { color: #e8a317; }
  .sh-path-card:hover .sh-path-link { text-decoration: underline; }

  /* ============================================================
     COMMON QUESTIONS
     ============================================================ */
  .sh-problems {
    padding: 65px 0 60px;
  }
  .sh-problems-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .sh-problem-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    transition: box-shadow var(--transition), transform var(--transition);
    color: var(--text);
    display: block;
  }
  .sh-problem-card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-2px);
    color: var(--text);
  }
  .sh-problem-icon {
    font-size: 28px;
    display: block;
    margin-bottom: 12px;
  }
  .sh-problem-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .sh-problem-card p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ============================================================
     MOST POPULAR GUIDES
     ============================================================ */
  .sh-guides {
    padding: 65px 0 60px;
  }
  .sh-guides-groups {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 40px;
  }
  .sh-guides-groups > div {
    display: flex;
    flex-direction: column;
  }
  .sh-guide-group-label {
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding-bottom: 10px;
    margin-bottom: 0;
    display: inline-block;
  }
  .sh-guide-group-label--top-picks {
    color: var(--accent);
    border-bottom: 3px solid var(--accent);
  }
  .sh-guide-group-label--reviews {
    color: #2dc0bb;
    border-bottom: 3px solid #2dc0bb;
  }
  .sh-guide-group-label--learn {
    color: #e8a317;
    border-bottom: 3px solid #e8a317;
  }
  .sh-guide-list {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-top: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .sh-guide-item {
    display: block;
    padding: 16px 18px;
    border-bottom: 1px solid var(--border);
    transition: background var(--transition);
    color: var(--text);
    flex: 1;
  }
  .sh-guide-item:last-child { border-bottom: none; }
  .sh-guide-item:hover {
    background: var(--accent-light);
    color: var(--text);
  }
  .sh-guide-item-title {
    font-size: 14px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 3px;
  }
  .sh-guide-item-desc {
    font-size: 13px;
    color: var(--text-light);
    line-height: 1.5;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 768px) {
    .sh-hero { padding: 60px 0 50px; }
    .sh-hero-title { font-size: 2rem; }
    .sh-hero-subtitle { font-size: 1rem; }

    .sh-intro-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .sh-paths-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }

    .sh-problems-grid { grid-template-columns: 1fr; }

    .sh-guides-groups { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .sh-hero-title { font-size: 1.65rem; }
    .sh-hero { padding: 48px 0 40px; }
    .sh-section-title { font-size: 1.5rem; }
  }
</style>

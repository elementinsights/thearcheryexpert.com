---
import { getCollection } from 'astro:content';
import CategoryLayout from '../../../layouts/CategoryLayout.astro';
import { siteConfig } from '../../../../site.config';

const INITIAL_COUNT = 6;

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map(p => p.data.category))];

  const allCategorySlugs = [
    ...siteConfig.categories.map(c => c.slug),
    ...categories.map(c => c.toLowerCase().replace(/\s+/g, '-')),
  ];
  const uniqueSlugs = [...new Set(allCategorySlugs)];

  return uniqueSlugs.map(slug => {
    const catPosts = posts
      .filter(p => p.data.category.toLowerCase().replace(/\s+/g, '-') === slug)
      .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
    const configCat = siteConfig.categories.find(c => c.slug === slug);
    const catName = configCat?.name || slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());

    return {
      params: { category: slug },
      props: { categoryName: catName, categorySlug: slug, allPosts: catPosts },
    };
  });
}

const { categoryName, categorySlug, allPosts } = Astro.props;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": categoryName,
    "url": `${siteConfig.url}/category/${categorySlug}/`,
    "isPartOf": { "@type": "WebSite", "name": siteConfig.name, "url": siteConfig.url },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteConfig.url },
      { "@type": "ListItem", "position": 2, "name": categoryName, "item": `${siteConfig.url}/category/${categorySlug}/` },
    ],
  },
];

const popularPosts = allPosts.slice(0, 5).map((p: any) => ({
  title: p.data.title,
  href: `/${p.id}/`,
  date: p.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
}));
---

<CategoryLayout
  title={categoryName}
  description={`Browse all ${categoryName} articles — reviews, comparisons, and buying guides.`}
  subtitle={`In-depth reviews, comparisons, and buying guides for every type of ${categoryName.toLowerCase()} — tested and reviewed by our team.`}
  activeNav={categorySlug}
  schema={schema}
  popularPosts={popularPosts}
  postCount={allPosts.length}
>
  <div class="article-grid">
    {allPosts.length > 0 ? (
      allPosts.map((post: any, i: number) => (
        <article class={`article-card animate-on-scroll${i >= INITIAL_COUNT ? ' hidden-card' : ''}`}>
          {post.data.image && (
            <a href={`/${post.id}/`} class="article-card-img">
              <img src={post.data.image} alt={post.data.imageAlt || post.data.title} width="400" height="200" loading={i < 2 ? 'eager' : 'lazy'} />
              <span class="article-card-badge">{post.data.postType.replace('-', ' ')}</span>
            </a>
          )}
          <div class="article-card-body">
            <h2 class="article-card-title"><a href={`/${post.id}/`}>{post.data.title}</a></h2>
            <p class="article-card-excerpt">{post.data.description}</p>
            <div class="article-card-meta">
              <span>{post.data.author || siteConfig.author.name}</span>
              <span class="article-card-meta-dot"></span>
              <span>{post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            </div>
          </div>
        </article>
      ))
    ) : (
      <p style="color: var(--text-secondary); padding: 40px 0;">No articles in this category yet.</p>
    )}

    {allPosts.length > INITIAL_COUNT && (
      <div class="load-more-wrap">
        <button class="load-more-btn" id="load-more-btn">Load More Articles</button>
      </div>
    )}
  </div>
</CategoryLayout>

<script is:inline>
(function() {
  var btn = document.getElementById('load-more-btn');
  if (!btn) return;
  var BATCH = 6;
  btn.addEventListener('click', function() {
    var hidden = document.querySelectorAll('.hidden-card');
    var count = 0;
    for (var i = 0; i < hidden.length && count < BATCH; i++, count++) {
      hidden[i].classList.remove('hidden-card');
    }
    if (document.querySelectorAll('.hidden-card').length === 0) {
      btn.style.display = 'none';
    }
  });
})();
</script>

<style>
  .article-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .article-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition), transform var(--transition);
    display: flex;
    flex-direction: column;
  }
  .article-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }
  .article-card-img {
    position: relative;
    height: 200px;
    overflow: hidden;
  }
  .article-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .article-card:hover .article-card-img img { transform: scale(1.05); }
  .article-card-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--accent);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 4px 10px;
    border-radius: 4px;
  }
  .article-card-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .article-card-title {
    font-size: 1.1rem;
    font-weight: 800;
    line-height: 1.35;
    margin-bottom: 10px;
  }
  .article-card-title a { color: var(--text); }
  .article-card-title a:hover { color: var(--accent); }
  .article-card-excerpt {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .article-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-light);
    flex-wrap: wrap;
  }
  .article-card-meta-dot {
    width: 3px;
    height: 3px;
    background: var(--text-light);
    border-radius: 50%;
  }

  /* Hidden cards & Load More */
  .hidden-card { display: none; }
  .load-more-wrap {
    grid-column: 1 / -1;
    text-align: center;
    margin-top: 30px;
  }
  .load-more-btn {
    display: inline-block;
    padding: 12px 36px;
    border: 2px solid var(--accent);
    color: var(--accent);
    font-size: 14px;
    font-weight: 700;
    border-radius: var(--radius);
    background: none;
    cursor: pointer;
    transition: all var(--transition);
  }
  .load-more-btn:hover { background: var(--accent); color: #fff; }

  @media (max-width: 768px) {
    .article-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .article-card-img { height: 180px; }
  }
</style>

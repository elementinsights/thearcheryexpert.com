---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../../site.config';

const cardColors = ['accent', 'teal', 'amber'];

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": `About ${siteConfig.name}`,
  "description": `Learn about ${siteConfig.name}'s mission, testing process, and the team behind our independent reviews.`,
  "url": `${siteConfig.url}/about/`,
  "isPartOf": { "@type": "WebSite", "name": siteConfig.name, "url": siteConfig.url }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteConfig.url },
    { "@type": "ListItem", "position": 2, "name": "About", "item": `${siteConfig.url}/about/` }
  ]
};
---

<BaseLayout
  title="About Us"
  description={`Learn about ${siteConfig.name}'s mission, testing process, and the team behind our independent reviews.`}
  schema={[aboutSchema, breadcrumbSchema]}
>

<!-- ============================================================
     1. ABOUT HERO
     ============================================================ -->
<section class="about-hero">
  <div class="hero-decor hero-decor-1"></div>
  <div class="hero-decor hero-decor-2"></div>
  <div class="hero-decor hero-decor-3"></div>
  <div class="container">
    <div class="about-hero-badge">
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
      Our Story
    </div>
    <h1 class="about-hero-title">About <span>{siteConfig.name}</span></h1>
    <p class="about-hero-subtitle">Helping readers find the right products through independent testing, honest reviews, and expert guidance you can actually trust.</p>
  </div>
</section>

<!-- ============================================================
     2. MISSION SECTION
     ============================================================ -->
<section class="mission-section">
  <div class="container">
    <div class="mission-grid">
      <div class="mission-content animate-on-scroll">
        <span class="mission-label">Our Mission</span>
        <h2 class="mission-title">Real archery experience. Honest gear reviews. No fluff.</h2>
        <p class="mission-text">The Archery Expert exists because most archery gear reviews are written by people who've never nocked an arrow. They copy specs from the manufacturer's website, add some stock photos, and call it a day.</p>
        <p class="mission-text">We actually shoot with the gear we review. Every bow, every sight, every release aid gets time on the range before we write a word about it. We compare real-world performance against what the box promises.</p>
        <p class="mission-text">Every recommendation is backed by real shooting sessions, not manufacturer talking points. We evaluate draw cycles, let-off feel, vibration dampening, arrow groupings, and long-term durability across hundreds of shots before publishing a single rating.</p>
        <p class="mission-text">No paid placements. No free samples influencing our scores. Just an archer sharing what actually works and what doesn't.</p>
      </div>
      <div class="stats-grid animate-on-scroll">
        <div class="stat-card">
          <div class="stat-icon">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
          </div>
          <div>
            <div class="stat-number">395</div>
            <div class="stat-label">Individual Products Evaluated</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <div>
            <div class="stat-number">5</div>
            <div class="stat-label">Product Categories</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <div class="stat-number">15+</div>
            <div class="stat-label">Years Behind the Bow</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     3. WHAT WE COVER
     ============================================================ -->
<section class="cover-section">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">What We Cover</span>
      <h2 class="section-title">Everything Archery, Covered</h2>
      <p class="section-subtitle">From compound bows to carbon arrows to backyard targets, we cover {siteConfig.categories.length} core categories of archery gear.</p>
    </div>
    <div class="cover-grid">
      {siteConfig.categories.map((cat, i) => {
        const color = cardColors[i % cardColors.length];
        const icons = [
          `<svg width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
          `<svg width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>`,
          `<svg width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
        ];
        return (
          <div class={`cover-card cover-card--${color} animate-on-scroll`}>
            <div class="cover-card-icon" set:html={icons[i % icons.length]} />
            <h3>{cat.name}</h3>
            <p>{cat.name === 'Accessories' ? 'From arm guards and release aids to quivers and bow cases, we review the gear that completes your archery setup and keeps you shooting comfortably.' :
               cat.name === 'Arrows' ? 'Carbon shafts, broadheads, vanes, and nocks. We test arrow components for flight consistency, penetration, and durability across different bow types.' :
               cat.name === 'Bows' ? 'Compound, recurve, longbow, and youth setups. We evaluate draw cycles, accuracy, build quality, and value to help you find the right bow.' :
               cat.name === 'Knowledge' ? 'Shooting form guides, safety rules, scoring systems, training programs, and archery history. The information side of the sport, all in one place.' :
               cat.name === 'Targets' ? 'Bag targets, 3D animal targets, foam blocks, and straw rounds. We test stopping power, arrow removal ease, and how long each target lasts.' :
               `Detailed coverage of ${cat.name.toLowerCase()} with honest reviews based on real-world testing.`}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>

<!-- ============================================================
     4. MEET THE FOUNDER
     ============================================================ -->
<section class="founder-section">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">Meet the Founder</span>
      <h2 class="section-title">The Person Behind the Testing</h2>
    </div>
    <div class="founder-card animate-on-scroll">
      <div class="founder-avatar-wrap">
        {siteConfig.author.image ? (
          <img class="founder-avatar-img" src={siteConfig.author.image} alt={siteConfig.author.name} width="120" height="120" />
        ) : (
          <div class="founder-avatar">{siteConfig.author.initial}</div>
        )}
      </div>
      <div class="founder-info">
        <h3 class="founder-name">{siteConfig.author.name}</h3>
        <p class="founder-role">{siteConfig.author.role}</p>
        <p class="founder-bio">{siteConfig.author.bio}</p>
        <p class="founder-bio">Every review on this site comes from real time spent at the range, in tree stands, and on 3D courses. I evaluate bows across their full draw cycle, test broadheads on ballistic media, and put accessories through extended shooting sessions before forming an opinion. If we haven't shot it, drawn it, or worn it ourselves, we don't review it.</p>
        <p class="founder-bio">I also cross-reference IBO speed ratings, ATA standards, and manufacturer warranty terms to make sure the numbers add up. When a bow claims 340 fps, I want to know at what draw weight and arrow grain that was measured.</p>
        <p class="founder-quote">"Archery taught me patience, focus, and the value of doing things right. I bring that same mindset to every gear review on this site."</p>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     5. OUR TESTING PROCESS
     ============================================================ -->
<section class="standards-section">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">Our Testing Process</span>
      <h2 class="section-title">How We Evaluate Archery Gear</h2>
      <p class="section-subtitle">Every recommendation is backed by real range time, not manufacturer spec sheets.</p>
    </div>
    <div class="standards-grid">
      <div class="standard-card animate-on-scroll">
        <div class="standard-icon">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 3h6M12 3v7l6.5 9.5a1 1 0 0 1-.83 1.5H6.33a1 1 0 0 1-.83-1.5L12 10V3"/></svg>
        </div>
        <div>
          <h3>Range-Tested Gear</h3>
          <p>Every bow, sight, release, and accessory gets actual shooting time on the range. We evaluate accuracy, comfort, durability, and ease of setup firsthand.</p>
        </div>
      </div>
      <div class="standard-card animate-on-scroll">
        <div class="standard-icon">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <div>
          <h3>Extended Use Testing</h3>
          <p>We don't shoot a bow once and write a review. Most gear goes through weeks of regular practice sessions before we publish. String wear, limb fatigue, and sight drift only show up over time.</p>
        </div>
      </div>
      <div class="standard-card animate-on-scroll">
        <div class="standard-icon">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        </div>
        <div>
          <h3>We Buy Our Own Gear</h3>
          <p>No free bows from manufacturers, no sponsored rankings. We buy every product at retail price so our reviews stay honest. Your trust matters more than a free quiver.</p>
        </div>
      </div>
      <div class="standard-card animate-on-scroll">
        <div class="standard-icon">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        </div>
        <div>
          <h3>Annual Updates</h3>
          <p>Manufacturers release new models every year. We revisit our top picks regularly and update rankings when better options hit the market or existing products change.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     6. WHY TRUST US
     ============================================================ -->
<section class="trust-section">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">Why Trust Us</span>
      <h2 class="section-title">Our Editorial Standards</h2>
      <p class="section-subtitle">Transparency is the foundation of everything we publish.</p>
    </div>
    <div class="trust-grid">
      <div class="trust-card animate-on-scroll">
        <h3>Affiliate Transparency</h3>
        <p>We earn commissions through Amazon affiliate links, and we disclose this on every article. Our revenue model never influences our rankings. Products earn their position based on range performance, not commission rates.</p>
      </div>
      <div class="trust-card animate-on-scroll">
        <h3>Experience-Based Ratings</h3>
        <p>Our editorial ratings are based on shooting performance, build quality, draw cycle feel, noise and vibration levels, durability over time, and value for money. We don't accept payments from manufacturers to adjust scores.</p>
      </div>
      <div class="trust-card animate-on-scroll">
        <h3>Regular Updates</h3>
        <p>Archery manufacturers release new models every year. We revisit our reviews and update availability, pricing, and recommendations when better options hit the market or existing products are discontinued.</p>
      </div>
      <div class="trust-card animate-on-scroll">
        <h3>Archer-First Approach</h3>
        <p>If a product doesn't perform well on the range, it doesn't make our list. We'd rather recommend fewer products honestly than pad a roundup with mediocre gear for the sake of affiliate clicks.</p>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  /* ============================================================
     ABOUT HERO
     ============================================================ */
  .about-hero {
    position: relative;
    background: var(--bg-dark);
    padding: 100px 0 90px;
    text-align: center;
    overflow: hidden;
  }
  .about-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(var(--accent-rgb), 0.15) 0%, transparent 70%),
      radial-gradient(ellipse 50% 80% at 80% 100%, rgba(var(--accent-rgb), 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 40% 50% at 10% 80%, rgba(99, 102, 241, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }
  .about-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }
  .about-hero .container {
    position: relative;
    z-index: 1;
  }
  .about-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(var(--accent-rgb), 0.15);
    color: var(--accent);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 16px;
    border-radius: 20px;
    margin-bottom: 24px;
    border: 1px solid rgba(var(--accent-rgb), 0.2);
  }
  .about-hero-title {
    font-size: 3.2rem;
    color: #fff;
    margin-bottom: 20px;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .about-hero-title span {
    background: linear-gradient(135deg, var(--accent), #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .about-hero-subtitle {
    font-size: 1.2rem;
    color: rgba(255,255,255,0.6);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
    font-weight: 400;
  }
  .hero-decor {
    position: absolute;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.08;
    pointer-events: none;
  }
  .hero-decor-1 { width: 300px; height: 300px; top: -80px; right: -60px; }
  .hero-decor-2 { width: 200px; height: 200px; bottom: -60px; left: -40px; }
  .hero-decor-3 { width: 120px; height: 120px; top: 40%; left: 15%; opacity: 0.05; }

  /* ============================================================
     MISSION SECTION
     ============================================================ */
  .mission-section {
    padding: 90px 0;
  }
  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .mission-label {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 12px;
  }
  .mission-title {
    font-size: 2.2rem;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  .mission-text {
    color: var(--text-secondary);
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 16px;
  }
  .mission-text:last-child { margin-bottom: 0; }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .stat-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .stat-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .stat-icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius);
    background: var(--accent-light);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--accent);
  }
  .stat-number {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--accent);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .stat-label {
    font-size: 14px;
    color: var(--text-secondary);
    font-weight: 500;
    margin-top: 2px;
  }

  /* ============================================================
     WHAT WE COVER
     ============================================================ */
  .cover-section {
    padding: 90px 0;
    background: var(--bg-alt);
  }
  .section-header {
    text-align: center;
    margin-bottom: 50px;
  }
  .section-label {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 12px;
  }
  .section-title {
    font-size: 2.2rem;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }
  .section-subtitle {
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto;
  }
  .cover-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .cover-card {
    background: var(--bg);
    border-radius: var(--radius-lg);
    padding: 36px 28px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition), box-shadow var(--transition);
    position: relative;
    overflow: hidden;
  }
  .cover-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
  }
  .cover-card--accent::before { background: var(--accent); }
  .cover-card--teal::before { background: #2dc0bb; }
  .cover-card--amber::before { background: #e8a317; }
  .cover-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .cover-card-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }
  .cover-card--accent .cover-card-icon {
    background: var(--accent-light);
    color: var(--accent);
  }
  .cover-card--teal .cover-card-icon {
    background: rgba(45, 192, 187, 0.1);
    color: #2dc0bb;
  }
  :global(html.dark) .cover-card--teal .cover-card-icon {
    background: rgba(45, 192, 187, 0.15);
  }
  .cover-card--amber .cover-card-icon {
    background: rgba(232, 163, 23, 0.1);
    color: #e8a317;
  }
  :global(html.dark) .cover-card--amber .cover-card-icon {
    background: rgba(232, 163, 23, 0.15);
  }
  .cover-card h3 {
    font-size: 1.2rem;
    margin-bottom: 10px;
    font-weight: 700;
  }
  .cover-card p {
    color: var(--text-secondary);
    font-size: 15px;
    line-height: 1.7;
  }

  /* ============================================================
     MEET THE FOUNDER
     ============================================================ */
  .founder-section {
    padding: 90px 0;
  }
  .founder-card {
    display: flex;
    gap: 48px;
    align-items: flex-start;
    max-width: 860px;
    margin: 0 auto;
  }
  .founder-avatar-wrap {
    flex-shrink: 0;
    text-align: center;
  }
  .founder-avatar-img {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
  }
  .founder-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: var(--accent-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.8rem;
    font-weight: 900;
    color: var(--accent);
    margin-bottom: 16px;
    border: 4px solid var(--bg);
    box-shadow: 0 0 0 3px var(--accent), var(--shadow);
  }
  .founder-name {
    font-size: 1.6rem;
    margin-bottom: 4px;
  }
  .founder-role {
    font-size: 15px;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 20px;
  }
  .founder-bio {
    color: var(--text-secondary);
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 14px;
  }
  .founder-bio:last-of-type { margin-bottom: 20px; }
  .founder-quote {
    color: var(--text-secondary);
    font-size: 15px;
    line-height: 1.8;
    font-style: italic;
    border-left: 3px solid var(--accent);
    padding-left: 20px;
    margin-top: 8px;
  }

  /* ============================================================
     OUR TESTING PROCESS
     ============================================================ */
  .standards-section {
    padding: 90px 0;
    background: var(--bg-alt);
  }
  .standards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .standard-card {
    background: var(--bg);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    display: flex;
    gap: 20px;
    align-items: flex-start;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .standard-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .standard-icon {
